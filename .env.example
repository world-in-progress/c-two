# ============================================================================
# C-Two Environment Variables
# ============================================================================
# Copy to `.env` and uncomment/edit as needed.
# Priority chain: explicit code (cc.set_*) > env vars / .env > defaults
# Set C2_ENV_FILE="" to disable .env loading entirely.
# ============================================================================

# --------------------------------------------------------------------------
# Transport Addresses
# --------------------------------------------------------------------------

# IPC server address (auto-generated UUID path if unset)
# C2_IPC_ADDRESS=ipc://my_server

# Relay URL for CRM registration and client name resolution
# C2_RELAY_ADDRESS=http://127.0.0.1:8080

# --------------------------------------------------------------------------
# Relay Server (c3 relay)
# --------------------------------------------------------------------------

# Bind address for the relay HTTP server  (default: 0.0.0.0:8080)
# C2_RELAY_BIND=0.0.0.0:8080

# Stable relay identifier for mesh protocol (auto-generated if unset)
# C2_RELAY_ID=relay-east-1

# Publicly reachable URL announced to mesh peers
# C2_RELAY_ADVERTISE_URL=http://relay-east-1.example.com:8080

# Comma-separated seed relay URLs for mesh mode
# C2_RELAY_SEEDS=http://relay-a:8080,http://relay-b:8080

# Idle upstream IPC connection timeout in seconds (default: 300)
# C2_RELAY_IDLE_TIMEOUT=300

# Anti-entropy digest exchange interval in seconds (default: 60.0)
# C2_RELAY_ANTI_ENTROPY_INTERVAL=60.0

# --------------------------------------------------------------------------
# Shared Memory (SHM)
# --------------------------------------------------------------------------

# Payload size threshold for SHM vs inline transfer in bytes (default: 4096)
# C2_SHM_THRESHOLD=4096

# --------------------------------------------------------------------------
# IPC Memory Pool
# --------------------------------------------------------------------------

# Buddy pool segment size in bytes (default: 268435456 = 256 MB)
# C2_IPC_POOL_SEGMENT_SIZE=268435456

# Max buddy pool segments, range 1–255 (default: 4)
# C2_IPC_MAX_POOL_SEGMENTS=4

# Max total pool memory in bytes (default: segment_size × max_segments)
# C2_IPC_MAX_POOL_MEMORY=1073741824

# Idle segment decay time in seconds (default: 60.0)
# C2_IPC_POOL_DECAY_SECONDS=60.0

# Enable/disable SHM pool (default: true)
# C2_IPC_POOL_ENABLED=true

# --------------------------------------------------------------------------
# IPC Frame / Payload Limits
# --------------------------------------------------------------------------

# Max inline frame size in bytes (default: 131072 = 128 KB)
# C2_IPC_MAX_FRAME_SIZE=131072

# Max single-call payload size in bytes (default: 2147483648 = 2 GB)
# C2_IPC_MAX_PAYLOAD_SIZE=2147483648

# Max concurrent pending requests per connection
# C2_IPC_MAX_PENDING_REQUESTS=256

# --------------------------------------------------------------------------
# IPC Heartbeat
# --------------------------------------------------------------------------

# Heartbeat interval in seconds, 0 disables (default: 30.0)
# C2_IPC_HEARTBEAT_INTERVAL=30.0

# Heartbeat timeout in seconds
# C2_IPC_HEARTBEAT_TIMEOUT=90.0

# --------------------------------------------------------------------------
# IPC Chunked Transfer
# --------------------------------------------------------------------------

# Max total in-flight chunks across all connections
# C2_IPC_MAX_TOTAL_CHUNKS=1024

# Chunk GC sweep interval in seconds
# C2_IPC_CHUNK_GC_INTERVAL=10.0

# Chunk threshold ratio (fraction of max_frame_size to trigger chunking)
# C2_IPC_CHUNK_THRESHOLD_RATIO=0.75

# Chunk assembler timeout in seconds
# C2_IPC_CHUNK_ASSEMBLER_TIMEOUT=30.0

# Max reassembly buffer memory in bytes
# C2_IPC_MAX_REASSEMBLY_BYTES=536870912

# Individual chunk size in bytes
# C2_IPC_CHUNK_SIZE=65536

# --------------------------------------------------------------------------
# IPC Reassembly Pool
# --------------------------------------------------------------------------

# Reassembly pool segment size in bytes
# C2_IPC_REASSEMBLY_SEGMENT_SIZE=67108864

# Max reassembly pool segments
# C2_IPC_REASSEMBLY_MAX_SEGMENTS=4
